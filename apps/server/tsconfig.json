{
	"extends": "@tsconfig/node24/tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		"skipLibCheck": true,

		"incremental": true,
		"tsBuildInfoFile": "./dist/.tsbuildinfo",

		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts"],
	"exclude": [
		"node_modules",
		"dist",
		"coverage",
		"tests",
		"**/*.test.ts",
		"**/*.spec.ts"
	]
}
